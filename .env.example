# انسخ هذا الملف إلى .env واملأ القيم. لا ترفع .env إلى GitHub إطلاقاً.

# Telegram (من my.telegram.org)
TG_API_ID=
TG_API_HASH=
TG_PHONE=+9665XXXXXXXX

# Supabase
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# إعدادات اختيارية
# أسماء محادثات الدعم مفصولة بفاصلة، اتركها فارغة لجلب الكل
TG_TARGET_CHATS=
LOOKBACK_HOURS=24
